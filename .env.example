# Для локальной разработки оставьте DJANGO_DEBUG=1.
# Для прода: DJANGO_DEBUG=0, длинный случайный DJANGO_SECRET_KEY и реальные домены.
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=django-insecure-local-dev-only-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
POSTGRES_DB=doorsky
POSTGRES_USER=doorsky
POSTGRES_PASSWORD=doorsky
POSTGRES_HOST=db
POSTGRES_PORT=5432
